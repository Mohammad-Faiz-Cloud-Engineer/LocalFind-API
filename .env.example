# LocalFind API Configuration
# Copy this file to .env and adjust values

# Server Configuration
HOST=0.0.0.0
PORT=7860

# CORS - Comma-separated list of allowed origins
# Use * for development, restrict in production
CORS_ORIGINS=*

# Application
APP_NAME=LocalFind API
APP_VERSION=4.3.7

# Contact Information
CONTACT_EMAIL=hello@localfind.com
CONTACT_PHONE=+91 8004037031

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
